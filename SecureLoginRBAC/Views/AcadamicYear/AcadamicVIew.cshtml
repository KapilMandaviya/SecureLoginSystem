<div class="offcanvas offcanvas-end" tabindex="-1" id="academicYearSidebar">
	<div class="offcanvas-header">
		<h5 id="formTitle">Create Academic Year</h5>
		<button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
	</div>

	<div class="offcanvas-body">

		<input type="hidden" id="editIndex">

		<div class="mb-3">
			<label class="form-label">Start Date</label>
			<input type="date" class="form-control" id="start_date" required>
			<small class="text-danger d-none" id="startDateError"></small>
		</div>

		<div class="mb-3">
			<label class="form-label">End Date</label>
			<input type="date" class="form-control" id="end_date" required>
			<small class="text-danger d-none" id="endDateError"></small>
		</div>

		<button type="button" class="btn btn-primary" id="btnSave">Save</button>
		<button type="button" class="btn btn-secondary" data-bs-dismiss="offcanvas">
			Cancel
		</button>

	</div>
</div>
@section Scripts {
	<script src="~/assets/js/custom-js/AcadamicView.js"></script>
 }