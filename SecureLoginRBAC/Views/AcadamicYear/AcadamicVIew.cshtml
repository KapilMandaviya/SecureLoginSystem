@using System.Security.Claims
@{
	Layout = "~/Views/Shared/_Layout.cshtml";
	ViewBag.pTitle = "Acadamic Year";
	ViewBag.Title = "Acadamic Year";
}
<link href="~/assets/custom-css/CustomMaster.css" rel="stylesheet" />

<!-- HEADER -->
<!-- ================= TABLE SECTION ================= -->
<div class="card mb-3" id="tableSection">

	<div class="card-body mb-3">
		<div class="d-flex justify-content-between align-items-center mb-2">
			<h4> Academic Year List</h4>

			@if (User.HasClaim("permission", "Admission_AcademicYear_CREATE"))
			{
			<button class="btn btn-primary" id="addBtn">
				<i class="uil uil-plus"></i> Create Acadamic Year
			</button>
			}

		</div>
		<table id="AcadamicYearDatatable" class="table table-bordered align-middle" style="width:100%;">
			<thead>
				<tr>
					<th class="sr_no_width">Sr No</th>
					<th>Start Date</th>
					<th>End Date</th>
					<th>Current Year</th>
					<th>Active Year</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody></tbody>
		</table>

	</div>
</div>

