<!doctype html>
<html lang="en">
<head>

	<partial name="~/Views/Shared/_title_meta.cshtml" />
	<partial name="~/Views/Shared/_head_css.cshtml" />
	<style>
		.loader-overlay {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: rgba(255, 255, 255, 0.7);
			
			align-items: center;
			justify-content: center;
			z-index: 9999;
			transition: opacity 0.2s ease;
			display: none; /* ensure visible immediately */
			opacity: 1; /* fully visible */
			pointer-events: all;
		}

		.spinner {
			width: 50px;
			height: 50px;
			border: 6px solid #ccc;
			border-top: 6px solid #007bff;
			border-radius: 50%;
			animation: spin 1s linear infinite;
		}

		@@keyframes spin {
			0%

		{
			transform: rotate(0deg);
		}

		100% {
			transform: rotate(360deg);
		}

		}


		.loader-overlay.show {
			opacity: 1;
			pointer-events: all;
		}
	</style>

</head>


<body class="authentication-bg">

	<!-- Loader -->
	<div id="loader" class="loader-overlay show">
		<div class="spinner"></div>
	</div>

	<!-- Begin page -->
	@RenderBody()

	<partial name="~/Views/Shared/_vendor_scripts.cshtml" />
	<!-- JAVASCRIPT -->
	@* @Html.Partial("~/Views/Shared/_vendor_scripts.cshtml") *@

	<!-- ✅ GLOBAL LOADER FUNCTIONS (MUST COME FIRST) -->
	<script>

			  window.showLoader = function () {
			const loader = document.getElementById("loader");
			loader.style.display = "flex";
			loader.classList.add("show");
			document.body.style.overflow = "hidden";
		};

		window.hideLoader = function () {
			const loader = document.getElementById("loader");
			setTimeout(() => loader.style.display = "none", 300); // match CSS transition
			loader.classList.remove("show");
			document.body.style.overflow = "";

			//document.body.classList.add("ready");
		};
		 


	</script>


	@RenderSection("scripts", required: false)
	<!-- App js -->
	<script src="~/assets/js/app.js"></script>


</body>

</html>