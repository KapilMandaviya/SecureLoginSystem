@{
	ViewData["Title"] = "Access Denied";
	Layout = "~/Views/Shared/_BlankLayout.cshtml";
}
<style>

	body {
		font-family: 'Inter', sans-serif;
		min-height: 100vh;
		background: #ffffff;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #111827;
	}

	/* subtle background blur blobs */

	.bg-blur {
		position: absolute;
		width: 260px;
		height: 260px;
		background: rgba(37, 99, 235, 0.15);
		filter: blur(120px);
		border-radius: 50%;
		top: 10%;
		left: 10%;
		z-index: 0;
	}

		.bg-blur.second {
			background: rgba(99, 102, 241, 0.12);
			bottom: 10%;
			right: 10%;
			top: auto;
			left: auto;
		}

	.glass-card {
		position: relative;
		z-index: 1;
		background: rgba(255, 255, 255, 0.6);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border-radius: 1.25rem;
		padding: 3rem 2.5rem;
		width: 100%;
		max-width: 420px;
		border: 1px solid rgba(0, 0, 0, 0.06);
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
		animation: fadeUp 0.6s ease;
	}

	@@keyframes fadeUp {
		from

	{
		opacity: 0;
		transform: translateY(20px);
	}

	to {
		opacity: 1;
		transform: translateY(0);
	}

	}

	.icon-lock {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.error-code {
		font-size: 4rem;
		font-weight: 700;
		letter-spacing: -1px;
	}

	.btn-primary {
		background-color: #2563eb;
		border: none;
	}

		.btn-primary:hover {
			background-color: #1d4ed8;
		}

	.btn-outline-secondary {
		border-color: #d1d5db;
		color: #374151;
	}

		.btn-outline-secondary:hover {
			background-color: #f3f4f6;
		}

	.text-muted {
		color: #6b7280 !important;
	}
</style>



<!-- background blur accents -->
<div class="bg-blur"></div>
<div class="bg-blur second"></div>

<div class="glass-card text-center">
	<div class="icon-lock">🔒</div>
	<div class="error-code">401</div>
	<h4 class="fw-semibold mb-3">Unauthorized</h4>
	<p class="text-muted mb-4">
		You don’t have access to this page.
		Please sign in with the correct account.
	</p>

	<div class="d-grid gap-3">
		<a href="@Url.Action("Logout","Login")" class="btn btn-primary btn-lg">Sign In</a>
		<a href="@Url.Action("Dashboard","Home")" class="btn btn-secondary">Back to Home</a>
	</div>
</div>
